generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Inquiry {
  id           String   @id @default(cuid())
  fullName     String
  mobile       String
  email        String
  organization String?
  services     String[]
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
}

model Contact {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String
  address      String?
  businessType String?
  service      String?
  message      String
  createdAt    DateTime @default(now())
}

model Candidate {
  id                  String   @id @default(cuid())
  fullName            String
  email               String
  mobile              String
  currentCity         String
  position            String
  experience          String
  qualification       String
  skills              String
  resumeUrl           String
  portfolioUrl        String?
  introduction        String?
  status              String   @default("New")
  createdAt           DateTime @default(now())
}

model MarketingInquiry {
  id           String   @id @default(cuid())
  fullName     String
  mobile       String
  email        String
  college      String
  mode         String   // e.g. "Work From Home" / "Office"
  focusAreas   String[] // Array of selected highlights
  duration     String   // e.g. "3 Months" / "6 Months"
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
}
