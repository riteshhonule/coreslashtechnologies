{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|\\.well-known/|sitemap\\.xml|robots\\.txt|favicon\\.ico|manifest\\.json|favicon-16x16\\.png|favicon-32x32\\.png|logo\\.png|coreslash_technologies_url_image\\.png|CoreslashTechnologies-solutions-main-logo).*)",
      "destination": "/index.html"
    }
  ]
}
